{
  "permissions": {
    "allow": [
      {
        "tool": "Bash",
        "command": "cd backend && *"
      },
      {
        "tool": "Bash",
        "command": "cd web && *"
      },
      {
        "tool": "Bash",
        "command": "npm run *"
      },
      {
        "tool": "Bash",
        "command": "python -m *"
      },
      {
        "tool": "Bash",
        "command": "pytest"
      },
      {
        "tool": "Bash",
        "command": "black"
      },
      {
        "tool": "Bash",
        "command": "flake8"
      },
      {
        "tool": "Bash",
        "command": "uvicorn"
      },
      {
        "tool": "Bash",
        "command": "celery"
      },
      {
        "tool": "Bash",
        "command": "redis-cli"
      },
      {
        "tool": "WebFetch",
        "host": "github.com"
      },
      {
        "tool": "WebFetch",
        "host": "raw.githubusercontent.com"
      },
      {
        "tool": "WebFetch",
        "host": "docs.claude.ai"
      }
    ],
    "deny": [
      {
        "tool": "Bash",
        "command": "rm -rf /"
      },
      {
        "tool": "Edit",
        "path": "**/.env"
      },
      {
        "tool": "Write",
        "path": "**/.env"
      }
    ]
  },
  "hooks": {
    "PreToolUse": {
      "Edit": [
        ".claude/hooks/protect-files.sh"
      ],
      "Write": [
        ".claude/hooks/protect-files.sh"
      ]
    },
    "PostToolUse": {
      "Edit": [
        ".claude/hooks/auto-format.sh"
      ],
      "Write": [
        ".claude/hooks/auto-format.sh"
      ]
    }
  },
  "defaults": {
    "autoMemoryEnabled": true,
    "outputStyle": "default"
  }
}
