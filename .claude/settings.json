{
  "permissions": {
    "allow": [
      "Bash: cd backend && *",
      "Bash: cd web && *",
      "Bash: npm run *",
      "Bash: python -m *",
      "Bash: pytest",
      "Bash: black",
      "Bash: flake8",
      "Bash: uvicorn",
      "Bash: celery",
      "Bash: redis-cli",
      "Bash: docker compose",
      "WebFetch: github.com",
      "WebFetch: raw.githubusercontent.com",
      "WebFetch: docs.claude.ai"
    ],
    "deny": [
      "Bash: rm -rf /",
      "Edit: **/.env",
      "Write: **/.env"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/protect-files.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/auto-format.sh"
          }
        ]
      }
    ]
  },
  "defaults": {
    "autoMemoryEnabled": true,
    "outputStyle": "default"
  }
}
