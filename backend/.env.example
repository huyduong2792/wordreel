# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True
CORS_ORIGINS=["http://localhost:3000", "http://localhost:4321"]

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# OpenAI Configuration (Optional - only for quiz generation)
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# AssemblyAI Configuration (Subtitle generation)
ASSEMBLYAI_API_KEY=your-assemblyai-api-key-here

# Video Configuration
MAX_VIDEO_SIZE_MB=100
SUPPORTED_VIDEO_FORMATS=mp4,webm,mov
CDN_BASE_URL=http://your-cdn-base-url

# TUS Upload Server
TUS_SERVER_URL=http://your-tus-server-url/v1/namespaces/default/tus
TUS_AUTH_TYPE=application_credential
TUS_CREDENTIAL_ID=your-tus-credential-id
TUS_CREDENTIAL_SECRET=your-tus-credential-secret
TUS_MAX_SIZE=104857600

# Application Settings
SECRET_KEY=your-secret-key-change-in-production
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO
